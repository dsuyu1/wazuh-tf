# ============================================================
# terraform.tfvars — VISI Wazuh Agent Deployment
# DO NOT commit this file to Git — add to .gitignore
# Use `terraform.tfvars.example` as a safe template to share
# ============================================================

aws_region  = "us-east-1"
env_prefix  = "visi-dev"

# Your IP only — don't leave this open
allowed_ssh_cidrs = ["YOUR.IP.HERE/32"]

ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# ── Wazuh Manager (your Pi) ───────────────────────────────
# If exposed via Cloudflare Tunnel hostname:
wazuh_manager_ip   = "wazuh.yourdomain.com"
wazuh_manager_port = 1514
wazuh_version      = "4.9.2"   # Must match your Pi manager version exactly

# Set this in your Pi's /var/ossec/etc/ossec.conf under <auth>
wazuh_registration_password = "YOUR_REGISTRATION_PASSWORD"

# ── Wazuh REST API ────────────────────────────────────────
# Exposed via Cloudflare Tunnel on port 55000
wazuh_api_url      = "https://wazuh.yourdomain.com:55000"
wazuh_api_user     = "wazuh"
wazuh_api_password = "YOUR_API_PASSWORD"

# ── Cloudflare Tunnel ─────────────────────────────────────
# Leave empty ("") if your Pi manager is directly reachable
cloudflare_tunnel_token = ""

# ── Agent Definitions ─────────────────────────────────────
# Add/remove agents here — each becomes one EC2 instance
agents = {
  "web-server-01" = {
    instance_type = "t3.micro"
    group         = "web-servers"
    disk_gb       = 20
  }
  "linux-endpoint-01" = {
    instance_type = "t3.micro"
    group         = "linux-endpoints"
    disk_gb       = 20
  }
  "vuln-target-01" = {
    instance_type = "t3.small"
    group         = "vuln-lab"
    disk_gb       = 30
  }
}
